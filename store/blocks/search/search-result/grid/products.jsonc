{
  "flex-layout.row#search-products": {
    "title": "Busca > Produtos",
    "props": {
      "blockClass": "search-products-container"
    },
    "children": ["flex-layout.col#search-products"]
  },

  "flex-layout.col#search-products": {
    "title": "Busca > Lista de produtos",
    "props": {
      "blockClass": "search-products-content"
    },
    "children": ["search-content"]
  },

  "search-content": {
    "title": "Busca > Conteúdo da busca",
    "props": {
      "blockClass": "search-content"
    },
    "blocks": ["gallery", "not-found"]
  },

  "gallery": {
    "title": "Busca > Galeria de produtos",
    "props": {
      "layouts": [
        {
          "name": "grid",
          "component": "GridSummary",
          "itemsPerRow": {
            "desktop": 3,
            "tablet": 3,
            "phone": 2
          }
        }
      ],
      "GridSummary": "product-summary.shelf"
    }
  }
}
