{
    "store.custom#faq": {
      "children": ["flex-layout.row#linha-bread","flex-layout.row#faq"]
    },
    "flex-layout.row#faq": {
      "props": {
        "blockClass": ["custom-container", "cms-page-container", "cms-faq"],
        "colSizing": "auto"
      },
      "children": [
        "flex-layout.col#side-cms-menu",
        "flex-layout.col#conteudo-faq"
      ]
      
    },
  
    "flex-layout.col#conteudo-faq": {
      "props": {
        "blockClass": ["container", "content-cms-teeeste"],
        "preventVerticalStretch": true
      },
      "children": ["rich-text#faq-title", "flex-layout.row#faq-content"]
    },
    "rich-text#faq-title": {
      "props": {
        "text": "# FAQ - Perguntas Frequentes",
        "blockClass": ["cms", "title"]
      }
    },
    "flex-layout.row#faq-content": {
      "props": {
        "blockClass": ["flex-column"],
        "colSizing": "auto"
      },
      "children": [
        
        "flex-layout.row#menu-cms-faq"
      ]
    },
    "flex-layout.row#menu-cms-faq": {
      "props": {
        "blockClass": ["menu-faq"]
      },
      "children": [
        "flex-layout.col#side-menu-cms-page-faq"
      ]
    },
    "flex-layout.col#side-menu-cms-page-faq": {
    "props": {
      "blockClass": ["cms-sidebar-faq"]
    },
    "children": [
      "disclosure-layout#menu-faq",
      "disclosure-layout#menu-faq1",
      "disclosure-layout#menu-faq2",
      "disclosure-layout#menu-faq3",
      "disclosure-layout#menu-faq4",
      "disclosure-layout#menu-faq5",
      "disclosure-layout#menu-faq6",
      "disclosure-layout#menu-faq7",
      "disclosure-layout#menu-faq8",
      "disclosure-layout#menu-faq9"
    ]
  },
  
  "disclosure-layout#menu-faq": {
    "props": {
      "blockClass": ["faq-dropdown"]
    },
    "children": [
      "disclosure-trigger#menu-faq",
      "disclosure-content#menu-faq"
    ]
  },
